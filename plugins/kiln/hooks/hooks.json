{
  "description": "Kiln pipeline enforcement hooks — delegation, sequencing, flags, safety",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash|SendMessage|Read|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/kiln-pipeline/scripts/enforce-pipeline.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/webfetch-responsive.sh",
            "timeout": 35
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/kiln-pipeline/scripts/audit-bash.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/skills/kiln-pipeline/scripts/audit-status-marker.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
