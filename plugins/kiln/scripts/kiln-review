#!/usr/bin/env node
'use strict'

const { createHash, randomUUID } = require('node:crypto')
const {
  appendFileSync,
  existsSync,
  mkdirSync,
  readdirSync,
  readFileSync,
  realpathSync,
  renameSync,
  statSync,
  unlinkSync,
  writeFileSync,
} = require('node:fs')
const { dirname, join, resolve, sep } = require('node:path')
const { spawnSync } = require('node:child_process')

const ACCEPT = 0
const REJECT = 10
const BLOCKED = 11
const TRANSPORT_FAILURE = 20
const CODEX_UNAVAILABLE = 21
const EFFORTS = ['low', 'medium', 'high', 'xhigh']
const LAW_HASH = /^[0-9a-f]{64}$/
const BROKEN_CODEX = /(?:unknown|unrecognized|unexpected|invalid).*(?:argument|option|subcommand)|(?:argument|option).*(?:not found|not recognized)/i
const SCHEMA = join(__dirname, 'review-schema.json')
// W8-S2: the screen family's shipped instrument and bounds. Keyframes ≤6, references ≤2,
// and the TOTAL image transport (2 required viewports + keyframes + references) capped
// at 10 — the whole pixel budget a grader ever sees. The DOM rides as a bounded text
// excerpt: enough to substantiate a clip-vs-authored call without flooding the packet.
const PERCEPTUAL_RUBRIC = join(__dirname, '..', 'data', 'perceptual-rubric.json')
const SCREEN_KEYFRAMES_MAX = 6
const SCREEN_REFERENCES_MAX = 2
const SCREEN_IMAGES_MAX = 10
const SCREEN_DOM_EXCERPT_LIMIT = 20000
// Screen findings pin evidence, not source: a viewport capture has no line number, so
// the location is an evidence path with an OPTIONAL :frame (film.webm:3) — the one
// place the screen family relaxes the shared path:line discipline.
const SCREEN_LOCATION = { pattern: /^[^:]+(?::\d+)?$/, message: 'location must be an evidence path with an optional :frame' }

function stop(fact, message, code) {
  process.stdout.write(`${fact}\n`)
  process.stderr.write(`kiln-review: ${message}\n`)
  process.exit(code)
}

function discard(file) {
  try {
    if (existsSync(file)) unlinkSync(file)
  } catch {
    // The original failure remains the machine fact.
  }
}

function readJson(file, label, discardOnFailure) {
  try {
    return JSON.parse(readFileSync(resolve(file), 'utf8'))
  } catch (error) {
    if (discardOnFailure) discard(discardOnFailure)
    stop('transport_failure', `${label}: ${error.message}`, TRANSPORT_FAILURE)
  }
}

function isObject(value) {
  return value !== null && typeof value === 'object' && !Array.isArray(value)
}

function stringArray(value) {
  return Array.isArray(value) && value.every((item) => typeof item === 'string')
}

function requestFrom(file) {
  const raw = readJson(file, 'invalid request')
  if (!isObject(raw)) stop('transport_failure', 'request must be a JSON object', TRANSPORT_FAILURE)
  if (!LAW_HASH.test(raw.law_hash)) stop('transport_failure', 'request law_hash must be a lowercase SHA-256 hex digest', TRANSPORT_FAILURE)
  if (typeof raw.reviewer_model !== 'string' || raw.reviewer_model.trim() === '') {
    stop('transport_failure', 'request reviewer_model must be a nonempty string', TRANSPORT_FAILURE)
  }
  const reviewerEffort = raw.reviewer_effort === undefined ? 'high' : raw.reviewer_effort
  if (!EFFORTS.includes(reviewerEffort)) {
    stop('reviewer_effort_invalid', `request reviewer_effort must be one of ${EFFORTS.join('|')} (absent defaults to high); ultra and unknown values are rejected`, TRANSPORT_FAILURE)
  }
  if (typeof raw.criteria !== 'string' || raw.criteria.trim() === '') {
    stop('transport_failure', 'request criteria must be a nonempty string', TRANSPORT_FAILURE)
  }
  for (const field of ['paths', 'failures', 'commands']) {
    if (!stringArray(raw[field])) stop('transport_failure', `request ${field} must be an array of strings`, TRANSPORT_FAILURE)
  }
  return {
    reviewerModel: raw.reviewer_model,
    reviewerEffort,
    lawHash: raw.law_hash,
    evidence: {
      criteria: raw.criteria,
      paths: raw.paths,
      failures: raw.failures,
      commands: raw.commands,
    },
  }
}

// A ratify request names the readable artifact and the rubric it is graded against,
// carries its own review_id (the caller issues it — unlike a slice review, which
// mints one), and picks the reviewer. There is no law_hash to supply: the ratified
// artifact's own bytes become the digest, computed at dispatch.
function ratifyRequestFrom(file) {
  const raw = readJson(file, 'invalid ratify request')
  if (!isObject(raw)) stop('transport_failure', 'ratify request must be a JSON object', TRANSPORT_FAILURE)
  if (typeof raw.review_id !== 'string' || raw.review_id.trim() === '') {
    stop('transport_failure', 'ratify request review_id must be a nonempty string', TRANSPORT_FAILURE)
  }
  if (typeof raw.reviewer_model !== 'string' || raw.reviewer_model.trim() === '') {
    stop('transport_failure', 'ratify request reviewer_model must be a nonempty string', TRANSPORT_FAILURE)
  }
  const reviewerEffort = raw.reviewer_effort === undefined ? 'high' : raw.reviewer_effort
  if (!EFFORTS.includes(reviewerEffort)) {
    stop('reviewer_effort_invalid', `request reviewer_effort must be one of ${EFFORTS.join('|')} (absent defaults to high); ultra and unknown values are rejected`, TRANSPORT_FAILURE)
  }
  if (typeof raw.artifact !== 'string' || raw.artifact.trim() === '') {
    stop('transport_failure', 'ratify request artifact must be a nonempty path string', TRANSPORT_FAILURE)
  }
  if (typeof raw.rubric !== 'string' || raw.rubric.trim() === '') {
    stop('transport_failure', 'ratify request rubric must be a nonempty path string', TRANSPORT_FAILURE)
  }
  return {
    reviewerModel: raw.reviewer_model,
    reviewerEffort,
    reviewId: raw.review_id,
    artifact: raw.artifact,
    rubric: raw.rubric,
  }
}

function rubricFrom(file) {
  const raw = readJson(file, 'invalid rubric')
  if (!isObject(raw) || !Array.isArray(raw.criteria) || raw.criteria.length === 0) {
    stop('transport_failure', 'rubric must be a JSON object with a nonempty criteria array', TRANSPORT_FAILURE)
  }
  for (const criterion of raw.criteria) {
    if (!isObject(criterion) || ['id', 'requirement', 'pass', 'fail'].some((key) => typeof criterion[key] !== 'string' || criterion[key].trim() === '')) {
      stop('transport_failure', 'each rubric criterion needs nonempty id, requirement, pass and fail strings', TRANSPORT_FAILURE)
    }
  }
  return raw.criteria
}

// W7-A1: the audit argv contract — closed facts only ride argv. Model and effort arrive
// as argv words (the kernel resolves them from tiers.json); the effort gate mirrors
// requestFrom so an unknown effort halts by name before any spawn. W8-S2: the screen
// family shares the identical contract, so the family label parameterizes the halt
// message and nothing else.
function auditRequest(model, effort, family = 'audit') {
  if (typeof model !== 'string' || model.trim() === '') {
    stop('transport_failure', `${family} reviewer model must be a nonempty string`, TRANSPORT_FAILURE)
  }
  if (!EFFORTS.includes(effort)) {
    stop('reviewer_effort_invalid', `${family} effort must be one of ${EFFORTS.join('|')}; ultra and unknown values are rejected`, TRANSPORT_FAILURE)
  }
  return { reviewerModel: model, reviewerEffort: effort }
}

// The audit CLI reads the CHECKED slices.json projection itself and derives every
// milestone fact: the closing block is the maximal contiguous run of same-label slices
// ending at the seam slice; the cumulative prefix is every slice up to and including it.
// Milestone labels may contain spaces — they ride only inside the composed prompt, so no
// stop() on this path ever interpolates a label into a log line. law_hash binds to the
// sealed digest at <kilnDir>/law/lock.hash, required present.
function auditFacts(kilnDir, seamSliceId) {
  if (typeof kilnDir !== 'string' || kilnDir.trim() === '') {
    stop('transport_failure', 'audit kilnDir must be a nonempty string', TRANSPORT_FAILURE)
  }
  if (typeof seamSliceId !== 'string' || seamSliceId.trim() === '') {
    stop('transport_failure', 'audit seam slice id must be a nonempty string', TRANSPORT_FAILURE)
  }
  const slices = readJson(join(kilnDir, 'slices.json'), 'invalid slices projection')
  if (!Array.isArray(slices) || slices.length === 0) {
    stop('transport_failure', 'slices.json must be a nonempty array', TRANSPORT_FAILURE)
  }
  // The kernel slice contract (parseSliceEntry), not a stricter one: a legacy bare
  // string entry is its own id with no label; an object entry carries id + optional
  // milestone. Ids and labels normalize by trim — the projection-agreement normalization
  // — so the audit, the kernel seam fact and the checked projection read identical
  // bytes, and every kernel-valid slices.json can derive its audit facts.
  const entries = slices.map((slice) => (typeof slice === 'string'
    ? { id: slice.trim(), milestone: '' }
    : {
      id: String((slice && slice.id) || '').trim(),
      milestone: String((slice && slice.milestone) || '').trim(),
    }))
  if (entries.some((entry) => entry.id === '')) {
    stop('transport_failure', 'every slices.json entry must carry a nonempty id', TRANSPORT_FAILURE)
  }
  const seam = entries.findIndex((entry) => entry.id === seamSliceId)
  if (seam < 0) stop('transport_failure', 'seam slice id not found in slices.json', TRANSPORT_FAILURE)
  let start = seam
  while (start > 0 && entries[start - 1].milestone === entries[seam].milestone) start -= 1
  let lawHash
  try {
    lawHash = readFileSync(join(kilnDir, 'law', 'lock.hash'), 'utf8').trim()
  } catch (error) {
    stop('transport_failure', `audit requires the sealed law/lock.hash: ${error.message}`, TRANSPORT_FAILURE)
  }
  if (!LAW_HASH.test(lawHash)) {
    stop('transport_failure', 'law/lock.hash must hold a lowercase SHA-256 hex digest', TRANSPORT_FAILURE)
  }
  return {
    lawHash,
    milestone: entries[seam].milestone,
    closingBlock: entries.slice(start, seam + 1).map((entry) => entry.id),
    sealedPrefix: entries.slice(0, seam + 1).map((entry) => entry.id),
  }
}

// W8-S2: the screen-family law facts — the verb derives the LAW Perceptual table rows
// ITSELF, with the PERCEPTUAL_TABLE_CHECK parser discipline (heading anchor, exact
// seven-cell header, GFM delimiter row, split on UNESCAPED `|` only so a lawful proxy
// command's GFM `\|` unescapes to the real operator), and binds the sealed lock.hash
// as packet TEXT — the schema's law_hash field belongs to the evidence digest here.
function screenLawFacts(kilnDir) {
  if (typeof kilnDir !== 'string' || kilnDir.trim() === '') {
    stop('transport_failure', 'screen kilnDir must be a nonempty string', TRANSPORT_FAILURE)
  }
  let law
  try {
    law = readFileSync(join(kilnDir, 'LAW.md'), 'utf8')
  } catch (error) {
    stop('transport_failure', `screen could not read LAW.md: ${error.message}`, TRANSPORT_FAILURE)
  }
  const head = ['criterion id', 'owning slice', 'dim', 'requirement', 'proxy command', 'expected', 'reference']
  const cells = (s) => s.split(/(?<!\\)\|/).slice(1, -1).map((x) => x.replace(/\\\|/g, '|').trim())
  const rows = []
  let state = 0
  for (const line of law.split('\n')) {
    const t = line.trim()
    const row = t.slice(0, 1) === '|'
    if (state === 0) {
      if (t.slice(0, 3) === '## ' && t.slice(3).trim().toLowerCase() === 'perceptual') state = 1
      continue
    }
    if (state === 1) {
      if (t.slice(0, 1) === '#') break
      if (!row) continue
      const c = cells(t)
      if (c.length === 7 && c.every((x, i) => x.toLowerCase() === head[i])) { state = 2; continue }
      stop('transport_failure', 'the LAW Perceptual table header row is malformed', TRANSPORT_FAILURE)
    }
    if (state === 2) {
      const c = t.split('|').slice(1, -1).map((x) => x.trim())
      if (row && c.length === 7 && c.every((x) => /^:?-{3,}:?$/.test(x))) { state = 3; continue }
      stop('transport_failure', 'the LAW Perceptual table delimiter row is malformed', TRANSPORT_FAILURE)
    }
    if (!row) break
    const c = cells(t)
    if (c.length !== 7) stop('transport_failure', 'every LAW Perceptual row must carry seven cells', TRANSPORT_FAILURE)
    rows.push({ criterion: c[0], slice: c[1], dim: c[2], requirement: c[3], proxy: c[4], expected: c[5], reference: c[6] })
  }
  if (state !== 3 || rows.length === 0) {
    stop('transport_failure', 'screen requires the sealed LAW.md to carry a Perceptual table with at least one row', TRANSPORT_FAILURE)
  }
  let lockHash
  try {
    lockHash = readFileSync(join(kilnDir, 'law', 'lock.hash'), 'utf8').trim()
  } catch (error) {
    stop('transport_failure', `screen requires the sealed law/lock.hash: ${error.message}`, TRANSPORT_FAILURE)
  }
  if (!LAW_HASH.test(lockHash)) {
    stop('transport_failure', 'law/lock.hash must hold a lowercase SHA-256 hex digest', TRANSPORT_FAILURE)
  }
  return { rows, lockHash }
}

// W8-S2 (Sol r3, adopted verbatim): CURRENT generation = the highest
// .kiln/evidence/gen-<n> dir containing a valid manifest.json. Validity here is the
// reader's floor — the bytes parse as a JSON object — because completeness is judged
// AFTER selection: an incomplete CURRENT manifest is an honest reject, never a silent
// fall-back onto a stale generation's evidence. A manifest-less dir (crash residue)
// occupies its number for the allocator but is invisible to every reader.
function currentGeneration(kilnDir) {
  const root = join(kilnDir, 'evidence')
  let names = []
  try {
    names = readdirSync(root)
  } catch {
    // No evidence root at all — the same honest no-CURRENT outcome as an empty one.
  }
  const numbers = names
    .map((name) => /^gen-(\d+)$/.exec(name))
    .filter(Boolean)
    .map((found) => Number(found[1]))
    .sort((a, b) => b - a)
  for (const number of numbers) {
    const dir = resolve(join(root, `gen-${number}`))
    let bytes, manifest
    try {
      bytes = readFileSync(join(dir, 'manifest.json'))
      manifest = JSON.parse(bytes.toString('utf8'))
    } catch {
      continue
    }
    if (!isObject(manifest)) continue
    return { number, dir, manifest, digest: createHash('sha256').update(bytes).digest('hex') }
  }
  stop('transport_failure', 'no CURRENT evidence generation — no .kiln/evidence/gen-* dir carries a valid manifest.json; the capture recipe runs first', TRANSPORT_FAILURE)
}

// W8-S2: the manifest completeness gate + the bounded image transport. Metadata floor:
// the manifest's gen number matches its dir, the probed runtime versions are recorded,
// and the counts equal the named files — a manifest that misdescribes itself never
// grades. Required classes: meta, dom, console, the two viewports, the film, and at
// least one labeled keyframe; references are optional. Bounds: keyframes ≤6,
// references ≤2, TOTAL image transport ≤10. Every named file resolves INSIDE the
// generation dir AND exists there physically — realpath containment, because a symlink
// pointing out is an outside path wearing an inside name. Any violation is a pre-spawn
// reject: exit 20, nothing published.
function screenEvidence(generation) {
  if (generation.manifest.generation !== generation.number) {
    stop('transport_failure', `manifest generation must equal its dir number ${generation.number}`, TRANSPORT_FAILURE)
  }
  const runtimes = isObject(generation.manifest.runtimes) ? generation.manifest.runtimes : {}
  for (const runtime of ['playwright', 'ffmpeg']) {
    if (typeof runtimes[runtime] !== 'string' || runtimes[runtime].trim() === '') {
      stop('transport_failure', `manifest missing recorded runtime version: ${runtime}`, TRANSPORT_FAILURE)
    }
  }
  const files = isObject(generation.manifest.files) ? generation.manifest.files : {}
  const entry = (name) => (typeof files[name] === 'string' && files[name].trim() !== '' ? files[name] : null)
  const list = (name) => (Array.isArray(files[name]) && files[name].every((p) => typeof p === 'string' && p.trim() !== '') ? files[name] : null)
  const required = {
    meta: entry('meta'),
    dom: entry('dom'),
    console: entry('console'),
    viewport_desktop: entry('viewport_desktop'),
    viewport_mobile: entry('viewport_mobile'),
    film: entry('film'),
  }
  const missing = Object.keys(required).find((name) => required[name] === null)
  if (missing) stop('transport_failure', `manifest missing required class ${missing}`, TRANSPORT_FAILURE)
  const keyframes = list('keyframes')
  if (!keyframes || keyframes.length === 0) {
    stop('transport_failure', 'manifest missing required class keyframes — at least one labeled keyframe', TRANSPORT_FAILURE)
  }
  const references = files.references === undefined ? [] : list('references')
  if (!references) stop('transport_failure', 'manifest references must be an array of nonempty paths', TRANSPORT_FAILURE)
  if (keyframes.length > SCREEN_KEYFRAMES_MAX) {
    stop('transport_failure', `manifest exceeds the keyframe bound: ${keyframes.length} > ${SCREEN_KEYFRAMES_MAX}`, TRANSPORT_FAILURE)
  }
  if (references.length > SCREEN_REFERENCES_MAX) {
    stop('transport_failure', `manifest exceeds the reference bound: ${references.length} > ${SCREEN_REFERENCES_MAX}`, TRANSPORT_FAILURE)
  }
  const imageNames = [required.viewport_desktop, required.viewport_mobile, ...keyframes, ...references]
  if (imageNames.length > SCREEN_IMAGES_MAX) {
    stop('transport_failure', `manifest exceeds the total image transport cap: ${imageNames.length} > ${SCREEN_IMAGES_MAX}`, TRANSPORT_FAILURE)
  }
  const counts = isObject(generation.manifest.counts) ? generation.manifest.counts : {}
  if (counts.keyframes !== keyframes.length || counts.references !== references.length || counts.images !== imageNames.length) {
    stop('transport_failure', 'manifest counts do not match its named files', TRANSPORT_FAILURE)
  }
  let dirReal
  try {
    dirReal = realpathSync(generation.dir)
  } catch (error) {
    stop('transport_failure', `generation dir unreadable: ${error.message}`, TRANSPORT_FAILURE)
  }
  const inside = (p) => {
    const abs = resolve(generation.dir, p)
    if (!abs.startsWith(generation.dir + sep)) {
      stop('transport_failure', `manifest names a path outside its generation dir: ${p}`, TRANSPORT_FAILURE)
    }
    let real
    try {
      real = realpathSync(abs)
      if (!statSync(real).isFile()) {
        stop('transport_failure', `manifest names a path that is not a regular file: ${p}`, TRANSPORT_FAILURE)
      }
    } catch (error) {
      stop('transport_failure', `manifest names a file that is not on disk: ${p}: ${error.message}`, TRANSPORT_FAILURE)
    }
    if (!real.startsWith(dirReal + sep)) {
      stop('transport_failure', `manifest names a file physically outside its generation dir: ${p}`, TRANSPORT_FAILURE)
    }
    return abs
  }
  // The film never rides the transport (its keyframes carry the story), but it is a
  // required class of the generation — it must exist physically like every other file.
  inside(required.film)
  return {
    images: imageNames.map(inside),
    imageNames,
    references,
    meta: inside(required.meta),
    dom: inside(required.dom),
    console: inside(required.console),
  }
}

// W8-S2: the shared screen packet body — the LAW Perceptual rows the verb derived, the
// whole shipped instrument (the rows' dims select from it), the evidence text (meta +
// console verbatim, the DOM as a bounded excerpt), and the attachment naming so the
// grader knows what each `-i` image is. The sealed LAW lock rides as text only — the
// schema's law_hash belongs to the manifest digest.
function screenPacket(facts, generation, evidence) {
  const text = (file, label) => {
    try {
      return readFileSync(file, 'utf8')
    } catch (error) {
      stop('transport_failure', `screen could not read ${label}: ${error.message}`, TRANSPORT_FAILURE)
    }
  }
  return {
    law_lock_hash: facts.lockHash,
    generation: generation.number,
    perceptual_criteria: facts.rows,
    rubric: rubricFrom(PERCEPTUAL_RUBRIC),
    attached_images: evidence.imageNames,
    reference_images: evidence.references,
    meta: text(evidence.meta, 'meta.json'),
    console_log: text(evidence.console, 'console.log'),
    dom_excerpt: text(evidence.dom, 'dom.html').slice(0, SCREEN_DOM_EXCERPT_LIMIT),
  }
}

function validateShape(value, expectedReviewId, expectedLawHash, allowedFindingIds, location) {
  // Every family but screen pins findings to source as path:line; the screen family
  // passes SCREEN_LOCATION because its findings pin evidence files where a line
  // number does not exist. Absent, the default preserves the baseline byte-for-byte.
  const locationRule = location || { pattern: /^.+:\d+(?::\d+)?$/, message: 'location must be path:line' }
  if (!isObject(value)) return 'gate output must be a JSON object'
  const keys = Object.keys(value)
  const expectedKeys = ['review_id', 'law_hash', 'findings', 'blockers', 'verdict']
  if (keys.length !== expectedKeys.length || expectedKeys.some((key) => !keys.includes(key))) {
    return 'gate output fields do not match review-schema.json'
  }
  if (typeof value.review_id !== 'string' || value.review_id.trim() === '') return 'review_id must be a nonempty string'
  if (!LAW_HASH.test(value.law_hash)) return 'law_hash must be a lowercase SHA-256 hex digest'
  if (value.review_id !== expectedReviewId) return 'review_id does not match the issued review id'
  // Locked-LAW equality holds its baseline precedence — right here, after the
  // review_id match and before the findings/verdict checks — so the slice and recheck
  // paths stay byte-for-byte behavior-identical. Ratify grades a not-yet-sealed LAW
  // and omits expectedLawHash, so this is skipped and ratify asserts the artifact's
  // own candidate digest instead.
  if (expectedLawHash !== undefined && value.law_hash !== expectedLawHash) return 'law_hash does not match the locked LAW'
  if (!Array.isArray(value.findings) || !stringArray(value.blockers)) return 'findings and blockers must be arrays'
  if (value.blockers.some((blocker) => blocker.trim() === '')) return 'blockers must be nonempty strings'
  if (!['accept', 'changes_required', 'blocked'].includes(value.verdict)) return 'verdict is not recognized'

  const ids = new Set()
  const findingKeys = ['id', 'criterion', 'location', 'failure_mode', 'evidence', 'minimal_fix']
  for (const finding of value.findings) {
    if (!isObject(finding)) return 'each finding must be an object'
    const keys = Object.keys(finding)
    if (keys.length !== findingKeys.length || findingKeys.some((key) => !keys.includes(key))) {
      return 'finding fields do not match review-schema.json'
    }
    if (findingKeys.some((key) => typeof finding[key] !== 'string' || finding[key].trim() === '')) {
      return 'finding fields must be nonempty strings'
    }
    if (!locationRule.pattern.test(finding.location)) return `finding ${finding.id} ${locationRule.message}`
    if (ids.has(finding.id)) return `duplicate finding id ${finding.id}`
    if (allowedFindingIds && !allowedFindingIds.has(finding.id)) return `recheck introduced out-of-scope finding id ${finding.id}`
    ids.add(finding.id)
  }

  if (value.verdict === 'accept' && (value.findings.length !== 0 || value.blockers.length !== 0)) {
    return 'accept requires empty findings and blockers'
  }
  if (value.verdict === 'changes_required' && (value.findings.length === 0 || value.blockers.length !== 0)) {
    return 'changes_required requires nonempty findings and empty blockers'
  }
  if (value.verdict === 'blocked' && value.blockers.length === 0) {
    return 'blocked requires nonempty blockers'
  }
  return null
}

// W7-02: the audit verb-level shape rules, layered ON TOP of the shared validateShape —
// review-schema.json stays byte-untouched. Every blockers entry must equal a findings id,
// so a blocker always carries criterion, location and minimal_fix through its finding; a
// blocked verdict with empty findings has nothing behind its blockers and is invalid.
// Violations take the validateShape failure path: transport_failure, exit 20, and the
// verdict is never published.
function auditShapeInvalid(gate) {
  if (gate.verdict === 'blocked' && gate.findings.length === 0) {
    return 'audit blocked verdict requires findings carrying its blocker ids'
  }
  const findingIds = new Set(gate.findings.map((finding) => finding.id))
  const orphan = gate.blockers.find((blocker) => !findingIds.has(blocker))
  if (orphan !== undefined) return `audit blocker ${orphan} does not equal any finding id`
  return null
}

// W8-S2: the screen verb-level rules, layered on the shared validateShape —
// review-schema.json stays byte-untouched. A perceptual grade can never block: hard
// failure belongs to the deterministic proxies (a proxy red is a law red through
// check.sh), so a blocked verdict or any blocker is invalid here; and every finding
// must pin a LAW perceptual criterion id — the cross-family ownership key. Violations
// take the validateShape failure path: transport_failure, exit 20, never published.
function screenShapeInvalid(gate, criterionIds) {
  if (gate.verdict === 'blocked') return 'screen verdict must be accept or changes_required — hard failure belongs to the law proxies'
  if (gate.blockers.length !== 0) return 'screen blockers must be empty — hard failure belongs to the law proxies'
  const off = gate.findings.find((finding) => !criterionIds.has(finding.criterion))
  if (off !== undefined) return `finding ${off.id} criterion ${off.criterion} is not a LAW perceptual criterion id`
  return null
}

function instructions(packet) {
  return `You are the terminal semantic gate reviewer. Inspect the repository at the working root and return only the schema-forced JSON object.

Review only the locked criteria. Report only substantiated criterion violations, never optional improvements. Creative direction, visual taste, and aesthetic choices belong to the builder — never raise them as a finding and never let them color a verdict; you rule on correctness against the locked criteria alone. For each finding, cite an exact repo-relative path:line location, the concrete failure, its evidence, and the smallest repair. Use stable finding IDs. The commands in the evidence packet were already executed kernel-side; their full output rides in check_receipt verbatim. Execute nothing — no commands, no tests, no builds: judge the diff against the law by reading the repository, with check_receipt as the only execution evidence. Receipt rows owned by slices not yet built in this run are expected pre-build evidence — judge only this slice's criteria (from the review request), never treat them as findings, and never filter or rewrite the receipt. Do not infer authorship, persona, or another reviewer's verdict.

Copy review_id and law_hash exactly. Verdict rules: accept only when findings and blockers are both empty; changes_required only for one or more repairable findings with no blockers; blocked only when the review cannot be completed, with one or more blocker reasons.
${packet.mode === 'recheck' ? '\nRecheck only the listed finding_ids against the repair_delta and current repository. Preserve each unresolved finding ID. Do not discover, add, or reopen any other finding. Accept when every listed finding is repaired.\n' : ''}
Evidence packet:
${JSON.stringify(packet, null, 2)}
`
}

function ratifyInstructions(packet) {
  return `You are the ratification reviewer. Grade the readable artifact below against the rubric and return only the schema-forced JSON object.

Judge the artifact against the rubric criteria alone. Report only substantiated criterion violations, never optional improvements and never matters of taste. For each finding, cite the artifact location as path:line, the concrete failure, evidence quoted from the artifact, and the smallest repair. Use stable finding IDs. Execute nothing: rule by reading the artifact text supplied in full below — do not inspect the repository and do not run any command.

Copy review_id and law_hash exactly into your output. law_hash is the sha256 digest of the artifact bytes; it seals the ratified content, so return it unchanged. Verdict rules: accept only when findings and blockers are both empty; changes_required only for one or more repairable findings with no blockers; blocked only when the review cannot be completed, with one or more blocker reasons.
${packet.mode === 'ratify-recheck' ? '\nRecheck only the listed finding_ids against the regenerated artifact. Preserve each unresolved finding ID. Do not discover, add, or reopen any other finding. Accept when every listed finding is repaired.\n' : ''}
Ratification packet:
${JSON.stringify(packet, null, 2)}
`
}

// W7-A1: the milestone audit prompt — review()'s prompt discipline, milestone-flavored
// instead of slice-flavored. The reviewer derives the milestone goal itself from LAW.md
// and the vision in-repo, judges goal-backward over the cumulative sealed prefix with
// focus on the closing block, pins LAW criterion ids and path:line locations, and
// executes nothing — the kernel-side check receipt rides the packet verbatim as the
// only execution evidence.
function auditInstructions(packet) {
  return `You are the milestone audit reviewer. Inspect the repository at the working root and return only the schema-forced JSON object.

Derive the milestone goal from .kiln/LAW.md and the vision documents in the repository, then judge goal-backward: over the cumulative sealed prefix in the audit packet, with focus on the closing block, check integrated reachability, the connections between slices, and delivery of the milestone goal. Report only substantiated criterion violations, never optional improvements. Creative direction, visual taste, and aesthetic choices belong to the builder — never raise them as a finding and never let them color a verdict. For each finding, pin the failed LAW criterion id in criterion and an exact repo-relative path:line in location, with the concrete failure, its evidence, and the smallest repair. Use stable finding IDs. The commands whose output rides in check_receipt were already executed kernel-side. Execute nothing — no commands, no tests, no builds: judge the milestone against the law by reading the repository, with check_receipt as the only execution evidence. Do not infer authorship, persona, or another reviewer's verdict.

Copy review_id and law_hash exactly. Every blockers entry must equal the id of one of your findings, so each blocker carries its criterion, location, and minimal fix through that finding. Verdict rules: accept only when findings and blockers are both empty; changes_required only for one or more repairable findings with no blockers; blocked only when the audit cannot be completed or the milestone goal is undeliverable, with one or more blocker ids naming findings.
${packet.mode === 'audit-recheck' ? '\nRecheck only the listed finding_ids against the repair_delta and current repository. Preserve each unresolved finding ID. Do not discover, add, or reopen any other finding. Accept when every listed finding is repaired.\n' : ''}
Audit packet:
${JSON.stringify(packet, null, 2)}
`
}

// W8-S2: the perceptual grading prompt — the review family's discipline pointed at
// pixels. The reviewer judges ONLY the LAW Perceptual rows, each on its named rubric
// dim per the shipped anchors; insufficient evidence is a finding, never a blocker;
// and law_hash binds the grade to the evidence — the sha256 of the graded generation's
// manifest.json (the ratify-family artifact-digest precedent, atomic and in-schema).
function screenInstructions(packet) {
  return `You are the perceptual grading reviewer. The attached images are the evidence generation named in the packet — the two required viewports, then the labeled keyframes, then any reference images, in the packet's attached_images order. Grade the rendered surface and return only the schema-forced JSON object.

Judge ONLY the perceptual criteria rows in the packet, each on its named rubric dim per the shipped rubric's anchors — never any other dimension, and never general taste beyond what a row's requirement pins. Report only substantiated criterion violations. For each finding, pin criterion = the row's LAW perceptual criterion id and location = an evidence path with an optional :frame (for example viewport-mobile.png or film.webm:3), with the concrete failure, its visual evidence, and the smallest repair. Use stable finding IDs. Insufficient evidence on a dim is a finding citing the rubric's insufficient_evidence line as its evidence — never a blocker. Execute nothing and install nothing: rule from the attached images and the packet text alone.

Copy review_id and law_hash exactly — law_hash is the sha256 digest of the graded generation's manifest.json and binds this verdict to that evidence. Verdict rules: accept only when findings and blockers are both empty; changes_required for one or more repairable findings. Never return blocked and never write a blocker: hard failure belongs to the law's deterministic proxies, not to this grade.
${packet.mode === 'screen-recheck' ? '\nRecheck only the listed finding_ids against the fresh evidence generation. Preserve each unresolved finding ID. Do not discover, add, or reopen any other finding. Accept when every listed finding is repaired.\n' : ''}${packet.mode === 'screen-escalate' ? '\nThis is a bounded second-family escalation of a held verdict: the packet carries ONLY the surviving criteria — grade them alone, on the same evidence generation; a finding on any other criterion invalidates the verdict.\n' : ''}
Evidence packet:
${JSON.stringify(packet, null, 2)}
`
}

function classifyFailure(run) {
  if (run.error && ['ENOENT', 'EACCES', 'ENOEXEC'].includes(run.error.code)) return CODEX_UNAVAILABLE
  if (run.error) return TRANSPORT_FAILURE
  const stderr = run.stderr || ''
  const incompatibleCli = BROKEN_CODEX.test(stderr) && /Usage:\s+codex(?: exec)?\b/i.test(stderr)
  if ([126, 127].includes(run.status) || incompatibleCli) return CODEX_UNAVAILABLE
  return TRANSPORT_FAILURE
}

// The shared codex-gate core: spawn the schema-forced reviewer, classify any
// failure honestly, hand the returned gate to the caller's own validator, then
// publish it and exit on the verdict. The prompt and the validator are the only
// things the slice and ratify paths differ on — everything else is identical, so
// both flows converge here rather than duplicate the spawn and the exit mapping.
// W8-S2: the screen family adds bounded `-i` image attachments — absent, the argv
// is byte-identical to the baseline.
function runGate(repo, request, prompt, outputFile, validate, images) {
  const output = resolve(outputFile)
  const temporary = join(dirname(output), `.gate-review.tmp-${process.pid}-${randomUUID()}`)
  const args = [
    'exec',
    '--ephemeral',
    '--sandbox', 'read-only',
    '--skip-git-repo-check',
    '-C', repo,
    '--model', request.reviewerModel,
    '-c', `model_reasoning_effort="${request.reviewerEffort}"`,
    '--output-schema', SCHEMA,
  ]
  for (const image of images || []) args.push('-i', image)
  args.push('-o', temporary, '-')
  const run = spawnSync('codex', args, {
    cwd: repo,
    input: prompt,
    encoding: 'utf8',
    maxBuffer: 4 * 1024 * 1024,
  })

  if (run.error || run.status !== 0) {
    discard(temporary)
    const code = classifyFailure(run)
    const detail = run.error ? run.error.message : (run.stderr || `codex exited ${run.status}`).trim().slice(-2000)
    stop(code === CODEX_UNAVAILABLE ? 'codex_unavailable' : 'transport_failure', detail, code)
  }
  if (!existsSync(temporary)) stop('transport_failure', 'codex produced no gate output', TRANSPORT_FAILURE)

  const gate = readJson(temporary, 'invalid codex gate output', temporary)
  const invalid = validate(gate)
  if (invalid) {
    discard(temporary)
    stop('transport_failure', invalid, TRANSPORT_FAILURE)
  }
  try {
    renameSync(temporary, output)
  } catch (error) {
    discard(temporary)
    stop('transport_failure', `could not publish gate output: ${error.message}`, TRANSPORT_FAILURE)
  }

  const exits = { accept: ACCEPT, changes_required: REJECT, blocked: BLOCKED }
  const facts = { accept: 'accept', changes_required: 'reject', blocked: 'blocked' }
  process.stdout.write(`${facts[gate.verdict]}\n`)
  process.exit(exits[gate.verdict])
}

function invoke(repo, request, packet, outputFile, allowedFindingIds) {
  // The reviewer never executes: the kernel side runs the law checks and writes
  // .kiln/check-receipt.txt before every gate call. The receipt rides the packet
  // verbatim; a missing receipt is a broken contract, never a license to execute.
  let checkReceipt
  try {
    checkReceipt = readFileSync(join(repo, '.kiln', 'check-receipt.txt'), 'utf8')
  } catch (error) {
    stop('transport_failure', `check receipt unreadable: ${error.message} — the kernel executes the checks and writes .kiln/check-receipt.txt before the gate call; the reviewer executes nothing`, TRANSPORT_FAILURE)
  }
  packet.check_receipt = checkReceipt
  runGate(repo, request, instructions(packet), outputFile, (gate) =>
    validateShape(gate, packet.review_id, packet.law_hash, allowedFindingIds))
}

// W7-A1: the audit-family invoke — the SAME receipt gate as invoke() (the kernel runs
// the law checks and writes .kiln/check-receipt.txt before every gate call; the reviewer
// executes nothing; a missing receipt is a broken contract), then the shared runGate
// with the audit prompt and the audit verb-level shape rules layered on validateShape.
function invokeAudit(repo, request, packet, outputFile, allowedFindingIds) {
  let checkReceipt
  try {
    checkReceipt = readFileSync(join(repo, '.kiln', 'check-receipt.txt'), 'utf8')
  } catch (error) {
    stop('transport_failure', `check receipt unreadable: ${error.message} — the kernel executes the checks and writes .kiln/check-receipt.txt before the gate call; the reviewer executes nothing`, TRANSPORT_FAILURE)
  }
  packet.check_receipt = checkReceipt
  runGate(repo, request, auditInstructions(packet), outputFile, (gate) => {
    const shape = validateShape(gate, packet.review_id, packet.law_hash, allowedFindingIds)
    if (shape) return shape
    return auditShapeInvalid(gate)
  })
}

function repository(path) {
  try {
    const root = realpathSync(resolve(path))
    if (!statSync(root).isDirectory()) throw new Error('not a directory')
    return root
  } catch (error) {
    stop('transport_failure', `invalid repository: ${error.message}`, TRANSPORT_FAILURE)
  }
}

const [mode, ...args] = process.argv.slice(2)
if (mode === 'review' && args.length === 3) {
  const [repoPath, requestFile, outputFile] = args
  const request = requestFrom(requestFile)
  const packet = {
    mode: 'review',
    review_id: randomUUID(),
    law_hash: request.lawHash,
    ...request.evidence,
  }
  invoke(repository(repoPath), request, packet, outputFile)
} else if (mode === 'recheck' && args.length === 5) {
  const [repoPath, requestFile, priorFile, repairDeltaFile, outputFile] = args
  const request = requestFrom(requestFile)
  const prior = readJson(priorFile, 'invalid prior gate review')
  const priorShape = isObject(prior) && typeof prior.review_id === 'string' && typeof prior.law_hash === 'string'
  const priorError = priorShape ? validateShape(prior, prior.review_id, prior.law_hash) : 'prior gate review is malformed'
  if (priorError) stop('transport_failure', priorError, TRANSPORT_FAILURE)
  if (prior.verdict !== 'changes_required') {
    stop('transport_failure', 'recheck requires a prior changes_required verdict', TRANSPORT_FAILURE)
  }
  if (prior.law_hash !== request.lawHash) stop('transport_failure', 'request LAW hash differs from the prior review', TRANSPORT_FAILURE)

  let repairDelta
  try {
    repairDelta = readFileSync(resolve(repairDeltaFile), 'utf8')
  } catch (error) {
    stop('transport_failure', `invalid repair delta: ${error.message}`, TRANSPORT_FAILURE)
  }
  if (repairDelta.trim() === '') stop('transport_failure', 'repair delta must not be empty', TRANSPORT_FAILURE)

  const findingIds = new Set(prior.findings.map((finding) => finding.id))
  const packet = {
    mode: 'recheck',
    review_id: prior.review_id,
    law_hash: prior.law_hash,
    ...request.evidence,
    finding_ids: [...findingIds],
    repair_delta: repairDelta,
  }
  invoke(repository(repoPath), request, packet, outputFile, findingIds)
} else if (mode === 'append-seal' && args.length === 3) {
  // The recovered v3 "Thoth scribe": an opaque, trusted seal-append verb. The
  // kernel courier calls it instead of a bare shell append it declines to
  // moralize; the seals.log semantics live here. Closed label, nonempty slice.
  const [kilnDir, slice, label] = args
  if (label !== 'dual' && label !== 'single-family') {
    stop('transport_failure', 'append-seal label must be dual or single-family', TRANSPORT_FAILURE)
  }
  if (typeof slice !== 'string' || slice.trim() === '') {
    stop('transport_failure', 'append-seal slice id must be a nonempty string', TRANSPORT_FAILURE)
  }
  try {
    appendFileSync(join(kilnDir, 'seals.log'), `${slice} ${label}\n`)
  } catch (error) {
    stop('transport_failure', `append-seal could not write seals.log: ${error.message}`, TRANSPORT_FAILURE)
  }
  process.exit(ACCEPT)
} else if (mode === 'seal-law' && args.length === 1) {
  // The trusted LAW lock, content-blind: the same digest a card shell computes
  // via `sha256sum .kiln/LAW.md | cut -d' ' -f1`, now owned by the CLI so the
  // kernel can seal the LAW after cross-family ratification without reading it.
  // Byte format matches that pipeline exactly: 64-hex + one trailing newline.
  const [kilnDir] = args
  if (typeof kilnDir !== 'string' || kilnDir.trim() === '') {
    stop('transport_failure', 'seal-law kilnDir must be a nonempty string', TRANSPORT_FAILURE)
  }
  let law
  try {
    law = readFileSync(join(kilnDir, 'LAW.md'))
  } catch (error) {
    stop('transport_failure', `seal-law could not read LAW.md: ${error.message}`, TRANSPORT_FAILURE)
  }
  const digest = createHash('sha256').update(law).digest('hex')
  const target = join(kilnDir, 'law', 'lock.hash')
  try {
    mkdirSync(dirname(target), { recursive: true })
    const temporary = join(dirname(target), `.lock.hash.tmp-${process.pid}-${randomUUID()}`)
    writeFileSync(temporary, `${digest}\n`)
    renameSync(temporary, target)
  } catch (error) {
    stop('transport_failure', `seal-law could not write lock.hash: ${error.message}`, TRANSPORT_FAILURE)
  }
  process.exit(ACCEPT)
} else if (mode === 'ratify' && args.length === 3) {
  // Ratify a readable artifact against a rubric — the reusable "review an artifact
  // against a rubric" path whose first consumer is the not-yet-sealed LAW. There is
  // no locked digest to compare against yet (the seal is written only after accept),
  // so this path never runs the slice's locked-LAW equality; it asserts the echoed
  // law_hash against the artifact's OWN candidate digest, computed exactly as seal-law
  // computes lock.hash so the ratified bytes and the sealed digest are byte-identical.
  const [repoPath, requestFile, outputFile] = args
  const request = ratifyRequestFrom(requestFile)
  const repo = repository(repoPath)
  let artifactBytes
  try {
    artifactBytes = readFileSync(resolve(repo, request.artifact))
  } catch (error) {
    stop('transport_failure', `ratify artifact unreadable: ${error.message}`, TRANSPORT_FAILURE)
  }
  const candidateDigest = createHash('sha256').update(artifactBytes).digest('hex')
  const packet = {
    mode: 'ratify',
    review_id: request.reviewId,
    law_hash: candidateDigest,
    rubric: rubricFrom(request.rubric),
    artifact: artifactBytes.toString('utf8'),
  }
  runGate(repo, request, ratifyInstructions(packet), outputFile, (gate) => {
    const shape = validateShape(gate, packet.review_id)
    if (shape) return shape
    if (gate.law_hash !== candidateDigest) return 'law_hash does not match the ratified artifact digest'
    return null
  })
} else if (mode === 'ratify-recheck' && args.length === 4) {
  // W6-02: the ratify verb gains the cohort lineage it lacked. A recheck of an
  // already-graded artifact reuses the prior review_id and constrains the reviewer to
  // the prior finding cohort — the SAME allowedFindingIds + prior changes_required
  // discipline the build recheck enforces (validateShape's out-of-scope rule), so a
  // ratify repair round cannot introduce a finding id out of nowhere. The artifact is
  // regenerated between rounds (the LAW-ratify repair rewrites the whole LAW), so
  // law_hash tracks the CURRENT artifact digest, not the prior one; the reused
  // review_id carries the lineage instead.
  const [repoPath, requestFile, priorFile, outputFile] = args
  const request = ratifyRequestFrom(requestFile)
  const prior = readJson(priorFile, 'invalid prior ratify review')
  const priorShape = isObject(prior) && typeof prior.review_id === 'string' && typeof prior.law_hash === 'string'
  const priorError = priorShape ? validateShape(prior, prior.review_id, prior.law_hash) : 'prior ratify review is malformed'
  if (priorError) stop('transport_failure', priorError, TRANSPORT_FAILURE)
  if (prior.verdict !== 'changes_required') {
    stop('transport_failure', 'ratify-recheck requires a prior changes_required verdict', TRANSPORT_FAILURE)
  }
  if (prior.review_id !== request.reviewId) {
    stop('transport_failure', 'ratify-recheck request review_id differs from the prior review', TRANSPORT_FAILURE)
  }
  const repo = repository(repoPath)
  let artifactBytes
  try {
    artifactBytes = readFileSync(resolve(repo, request.artifact))
  } catch (error) {
    stop('transport_failure', `ratify artifact unreadable: ${error.message}`, TRANSPORT_FAILURE)
  }
  const candidateDigest = createHash('sha256').update(artifactBytes).digest('hex')
  const findingIds = new Set(prior.findings.map((finding) => finding.id))
  const packet = {
    mode: 'ratify-recheck',
    review_id: request.reviewId,
    law_hash: candidateDigest,
    rubric: rubricFrom(request.rubric),
    artifact: artifactBytes.toString('utf8'),
    finding_ids: [...findingIds],
  }
  runGate(repo, request, ratifyInstructions(packet), outputFile, (gate) => {
    const shape = validateShape(gate, packet.review_id, undefined, findingIds)
    if (shape) return shape
    if (gate.law_hash !== candidateDigest) return 'law_hash does not match the ratified artifact digest'
    return null
  })
} else if (mode === 'audit' && args.length === 6) {
  // W7-A1: the milestone-seam audit — one fresh goal-backward GPT reviewer over the
  // cumulative sealed prefix. argv carries closed facts only; every derived fact — the
  // closing block, the cumulative prefix, the milestone label (which may contain spaces
  // and rides only inside the composed prompt, never argv, never a log line) — is
  // computed here from the checked slices.json projection. law_hash binds to the sealed
  // lock.hash, the review_id is minted fresh exactly as review does, and the transport
  // is the review verb's: codex, read-only sandbox, schema-forced output, closed exits.
  const [repoPath, kilnDir, seamSliceId, model, effort, outputFile] = args
  const request = auditRequest(model, effort)
  const repo = repository(repoPath)
  const facts = auditFacts(kilnDir, seamSliceId)
  const packet = {
    mode: 'audit',
    review_id: randomUUID(),
    law_hash: facts.lawHash,
    seam_slice: seamSliceId,
    milestone: facts.milestone,
    closing_block: facts.closingBlock,
    sealed_prefix: facts.sealedPrefix,
  }
  invokeAudit(repo, request, packet, outputFile)
} else if (mode === 'audit-recheck' && args.length === 8) {
  // W7-A1: the audit recheck mirrors recheck with two deliberate widenings: the prior
  // verdict may be changes_required OR blocked (audit blockers reopen their owning
  // slices, so a blocked milestone is recoverable at this gate), and the law binding is
  // the sealed lock.hash rather than a request law_hash. The cohort is the prior finding
  // ids — reuse-or-clear, no new or renamed ids — and the same audit verb-level shape
  // rules gate the prior (an artifact invalid for the audit family establishes no
  // lineage) and the current output.
  const [repoPath, kilnDir, seamSliceId, model, effort, priorFile, repairDeltaFile, outputFile] = args
  const request = auditRequest(model, effort)
  const repo = repository(repoPath)
  const facts = auditFacts(kilnDir, seamSliceId)
  const prior = readJson(priorFile, 'invalid prior audit review')
  const priorShape = isObject(prior) && typeof prior.review_id === 'string' && typeof prior.law_hash === 'string'
  // The prior must satisfy the FULL audit-family shape — shared validateShape plus the
  // audit verb-level rules — before it can seed a cohort: a blocked prior with empty
  // findings or an orphan blocker id was never a publishable audit, so it cannot
  // establish recheck lineage here either.
  const priorError = priorShape
    ? (validateShape(prior, prior.review_id, prior.law_hash) || auditShapeInvalid(prior))
    : 'prior audit review is malformed'
  if (priorError) stop('transport_failure', priorError, TRANSPORT_FAILURE)
  if (prior.verdict !== 'changes_required' && prior.verdict !== 'blocked') {
    stop('transport_failure', 'audit-recheck requires a prior changes_required or blocked verdict', TRANSPORT_FAILURE)
  }
  if (prior.law_hash !== facts.lawHash) {
    stop('transport_failure', 'prior audit law_hash differs from the sealed law/lock.hash', TRANSPORT_FAILURE)
  }
  let repairDelta
  try {
    repairDelta = readFileSync(resolve(repairDeltaFile), 'utf8')
  } catch (error) {
    stop('transport_failure', `invalid repair delta: ${error.message}`, TRANSPORT_FAILURE)
  }
  if (repairDelta.trim() === '') stop('transport_failure', 'repair delta must not be empty', TRANSPORT_FAILURE)
  const findingIds = new Set(prior.findings.map((finding) => finding.id))
  const packet = {
    mode: 'audit-recheck',
    review_id: prior.review_id,
    law_hash: facts.lawHash,
    seam_slice: seamSliceId,
    milestone: facts.milestone,
    closing_block: facts.closingBlock,
    sealed_prefix: facts.sealedPrefix,
    finding_ids: [...findingIds],
    repair_delta: repairDelta,
  }
  invokeAudit(repo, request, packet, outputFile, findingIds)
} else if (mode === 'append-audit' && args.length === 2) {
  // W7: the ONLY writer of audits.log — append-seal's milestone-seam mirror. The kernel
  // promotes an accepted audit through this trusted verb, never a bare shell append; the
  // audits.log semantics live here. The outcome label is the fixed `accept`, and the
  // seam slice id is gated with the SAME slice-id charset the kernel enforces at slice
  // intake (parseSliceEntry SLICE_ID) — one contract, so every id a build can carry
  // publishes. The id becomes the grep anchor `^<id> `, where whitespace or control
  // bytes could forge or split a log line; slash is inside the set (path-like ids such
  // as feature/ui are anchor-safe).
  const [kilnDir, seamSliceId] = args
  if (typeof kilnDir !== 'string' || kilnDir.trim() === '') {
    stop('transport_failure', 'append-audit kilnDir must be a nonempty string', TRANSPORT_FAILURE)
  }
  if (typeof seamSliceId !== 'string' || !/^[A-Za-z0-9._/-]+$/.test(seamSliceId)) {
    stop('transport_failure', 'append-audit seam slice id must be nonempty using only letters, digits, dot, underscore, hyphen or slash', TRANSPORT_FAILURE)
  }
  try {
    appendFileSync(join(kilnDir, 'audits.log'), `${seamSliceId} accept\n`)
  } catch (error) {
    stop('transport_failure', `append-audit could not write audits.log: ${error.message}`, TRANSPORT_FAILURE)
  }
  process.exit(ACCEPT)
} else if (mode === 'screen' && args.length === 5) {
  // W8-S2: the perceptual screen — one fresh grader over the CURRENT evidence
  // generation's bounded pixels. argv carries closed facts only; the verb derives the
  // LAW Perceptual rows, the sealed lock.hash (packet text), and the CURRENT
  // generation itself. Pre-spawn rejects (exit 20, nothing published, no codex): no
  // CURRENT generation, a manifest missing any required class, any bound exceeded.
  // The transport is the review family's — read-only codex, the byte-untouched
  // review-schema.json, closed exits — plus the manifest's images on `-i`. Binding:
  // the schema's law_hash = sha256 of the graded generation's manifest.json, asserted
  // post-run exactly as ratify asserts its artifact digest.
  const [repoPath, kilnDir, model, effort, outputFile] = args
  const request = auditRequest(model, effort, 'screen')
  const repo = repository(repoPath)
  const facts = screenLawFacts(kilnDir)
  const generation = currentGeneration(kilnDir)
  const evidence = screenEvidence(generation)
  const criterionIds = new Set(facts.rows.map((row) => row.criterion))
  const packet = {
    mode: 'screen',
    review_id: randomUUID(),
    law_hash: generation.digest,
    ...screenPacket(facts, generation, evidence),
  }
  runGate(repo, request, screenInstructions(packet), outputFile, (gate) => {
    const shape = validateShape(gate, packet.review_id, undefined, undefined, SCREEN_LOCATION)
    if (shape) return shape
    if (gate.law_hash !== generation.digest) return 'law_hash does not match the graded generation manifest digest'
    return screenShapeInvalid(gate, criterionIds)
  }, evidence.images)
} else if (mode === 'screen-recheck' && args.length === 7) {
  // W8-S2: the screen recheck — the recheck discipline pointed at fresh pixels. Same
  // review_id lineage, cohort reuse-or-clear over the prior finding ids, and
  // FRESHNESS: the CURRENT manifest digest MUST DIFFER from the prior verdict's
  // law_hash, so a regrade can never re-grade the very evidence that already failed.
  // delta IS the fresh CURRENT manifest: the argv path must resolve to it, and the
  // bytes read must re-hash to the selected digest — path- and digest-bound, so no
  // free text ever rides the packet as repair_delta.
  const [repoPath, kilnDir, model, effort, priorFile, deltaFile, outputFile] = args
  const request = auditRequest(model, effort, 'screen')
  const repo = repository(repoPath)
  const facts = screenLawFacts(kilnDir)
  const criterionIds = new Set(facts.rows.map((row) => row.criterion))
  const prior = readJson(priorFile, 'invalid prior screen review')
  const priorShape = isObject(prior) && typeof prior.review_id === 'string' && typeof prior.law_hash === 'string'
  // The prior must satisfy the FULL screen-family shape — a blocked verdict, a
  // blocker, or an off-table criterion was never a publishable screen verdict, so it
  // establishes no recheck lineage (the audit-recheck precedent).
  const priorError = priorShape
    ? (validateShape(prior, prior.review_id, prior.law_hash, undefined, SCREEN_LOCATION) || screenShapeInvalid(prior, criterionIds))
    : 'prior screen review is malformed'
  if (priorError) stop('transport_failure', priorError, TRANSPORT_FAILURE)
  if (prior.verdict !== 'changes_required') {
    stop('transport_failure', 'screen-recheck requires a prior changes_required verdict', TRANSPORT_FAILURE)
  }
  const generation = currentGeneration(kilnDir)
  if (generation.digest === prior.law_hash) {
    stop('transport_failure', 'screen-recheck requires fresh evidence — the CURRENT manifest digest equals the prior graded generation', TRANSPORT_FAILURE)
  }
  const evidence = screenEvidence(generation)
  if (resolve(deltaFile) !== join(generation.dir, 'manifest.json')) {
    stop('transport_failure', 'screen-recheck delta must be the CURRENT generation manifest path', TRANSPORT_FAILURE)
  }
  let deltaBytes
  try {
    deltaBytes = readFileSync(resolve(deltaFile))
  } catch (error) {
    stop('transport_failure', `invalid fresh-manifest delta: ${error.message}`, TRANSPORT_FAILURE)
  }
  if (createHash('sha256').update(deltaBytes).digest('hex') !== generation.digest) {
    stop('transport_failure', 'fresh-manifest delta bytes do not match the CURRENT manifest digest', TRANSPORT_FAILURE)
  }
  const delta = deltaBytes.toString('utf8')
  const findingIds = new Set(prior.findings.map((finding) => finding.id))
  const packet = {
    mode: 'screen-recheck',
    review_id: prior.review_id,
    law_hash: generation.digest,
    ...screenPacket(facts, generation, evidence),
    finding_ids: [...findingIds],
    repair_delta: delta,
  }
  runGate(repo, request, screenInstructions(packet), outputFile, (gate) => {
    const shape = validateShape(gate, packet.review_id, undefined, findingIds, SCREEN_LOCATION)
    if (shape) return shape
    if (gate.law_hash !== generation.digest) return 'law_hash does not match the graded generation manifest digest'
    return screenShapeInvalid(gate, criterionIds)
  }, evidence.images)
} else if (mode === 'screen-escalate' && args.length === 6) {
  // W8-S3 (ONLY-survivors): the bounded second-family escalation of a HELD screen
  // verdict. The held verdict rides argv as a closed path; the verb re-validates it
  // with the FULL screen-family shape (an artifact invalid for the family names no
  // survivors), derives the surviving criterion ids from its findings, and packets
  // ONLY the surviving rows — the grader never sees the rest of the table. A fresh
  // review_id: this is a second mind's scoped grade, not a lineage recheck. Scope is
  // enforced pre-publish exactly as table membership is on screen: a finding outside
  // the survivors is exit 20, and the off-scope verdict is never published.
  const [repoPath, kilnDir, model, effort, heldFile, outputFile] = args
  const request = auditRequest(model, effort, 'screen')
  const repo = repository(repoPath)
  const facts = screenLawFacts(kilnDir)
  const criterionIds = new Set(facts.rows.map((row) => row.criterion))
  const held = readJson(heldFile, 'invalid held screen review')
  const heldShape = isObject(held) && typeof held.review_id === 'string' && typeof held.law_hash === 'string'
  const heldError = heldShape
    ? (validateShape(held, held.review_id, held.law_hash, undefined, SCREEN_LOCATION) || screenShapeInvalid(held, criterionIds))
    : 'held screen review is malformed'
  if (heldError) stop('transport_failure', heldError, TRANSPORT_FAILURE)
  if (held.verdict !== 'changes_required') {
    stop('transport_failure', 'screen-escalate requires a held changes_required verdict', TRANSPORT_FAILURE)
  }
  const survivors = new Set(held.findings.map((finding) => finding.criterion))
  const generation = currentGeneration(kilnDir)
  const evidence = screenEvidence(generation)
  const packet = {
    mode: 'screen-escalate',
    review_id: randomUUID(),
    law_hash: generation.digest,
    ...screenPacket({ ...facts, rows: facts.rows.filter((row) => survivors.has(row.criterion)) }, generation, evidence),
  }
  runGate(repo, request, screenInstructions(packet), outputFile, (gate) => {
    const shape = validateShape(gate, packet.review_id, undefined, undefined, SCREEN_LOCATION)
    if (shape) return shape
    if (gate.law_hash !== generation.digest) return 'law_hash does not match the graded generation manifest digest'
    const family = screenShapeInvalid(gate, criterionIds)
    if (family) return family
    const off = gate.findings.find((finding) => !survivors.has(finding.criterion))
    if (off !== undefined) return `finding ${off.id} criterion ${off.criterion} is outside the surviving escalation scope`
    return null
  }, evidence.images)
} else {
  stop(
    'transport_failure',
    'usage: kiln-review review <repo> <request.json> <gate-review.json> | kiln-review recheck <repo> <request.json> <prior-gate-review.json> <repair-delta> <gate-review.json> | kiln-review append-seal <kilnDir> <slice> <label> | kiln-review seal-law <kilnDir> | kiln-review ratify <repo> <request.json> <gate-review.json> | kiln-review ratify-recheck <repo> <request.json> <prior-gate-review.json> <gate-review.json> | kiln-review audit <repo> <kilnDir> <seamSliceId> <model> <effort> <gate-review.json> | kiln-review audit-recheck <repo> <kilnDir> <seamSliceId> <model> <effort> <prior-gate-review.json> <repair-delta> <gate-review.json> | kiln-review append-audit <kilnDir> <seamSliceId> | kiln-review screen <repo> <kilnDir> <model> <effort> <gate-review.json> | kiln-review screen-recheck <repo> <kilnDir> <model> <effort> <prior-gate-review.json> <fresh-manifest> <gate-review.json> | kiln-review screen-escalate <repo> <kilnDir> <model> <effort> <held-screen-review.json> <gate-review.json>',
    TRANSPORT_FAILURE,
  )
}
