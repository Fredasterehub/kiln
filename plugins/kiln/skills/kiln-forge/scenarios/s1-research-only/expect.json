{
  "scenario": "S1",
  "name": "Research Only",
  "description": "Tests MI6 + field agents, progressive synthesis. Starts from Steps 1-2 complete.",
  "timeout_seconds": 600,
  "seed_source": "/DEV/finalkiln/.kiln/",
  "seed_state": {
    "stage": "research",
    "build_iteration": 0,
    "correction_cycle": 0,
    "milestone_count": 0,
