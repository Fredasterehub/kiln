  },
  "seed_artifacts": [
    ".kiln/STATE.md",
    ".kiln/docs/VISION.md",
    ".kiln/docs/vision-notes.md",
    ".kiln/docs/vision-priorities.md",
    ".kiln/docs/codebase-snapshot.md",
