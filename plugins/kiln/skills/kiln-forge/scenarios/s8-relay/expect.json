{
  "scenario": "S8",
  "name": "Step-Isolated Relay",
  "description": "Runs all 8 Kiln pipeline steps in isolated seeded workspaces with per-step timeouts and artifact checks.",
  "timeout_seconds": 2700,
  "seed_state": {
    "stage": "onboarding",
    "build_iteration": 0,
    "correction_cycle": 0,
    "milestone_count": 0,
    "milestones_complete": 0
  },
  "steps": [
    {
      "step": 1,
      "name": "onboarding",
      "timeout_seconds": 240,
      "seed": "empty-workspace",
      "artifacts": [
        {"path": ".kiln/MEMORY.md", "exists": true},
        {"path": ".kiln/docs/codebase-snapshot.md", "exists": true},
        {"path": ".kiln/docs/decisions.md", "exists": true},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "- **stage**: brainstorm"},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "step-2-brainstorm.md"}
      ]
    },
    {
      "step": "1b",
      "name": "onboarding-brownfield",
      "timeout_seconds": 300,
      "seed": "brownfield-codebase",
      "artifacts": [
        {"path": ".kiln/MEMORY.md", "exists": true},
        {"path": ".kiln/docs/codebase-snapshot.md", "exists": true},
        {"path": ".kiln/docs/decisions.md", "exists": true},
        {"path": ".kiln/docs/pitfalls.md", "exists": true},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "- **stage**: brainstorm"},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "step-2-brainstorm.md"}
      ]
    },
    {
      "step": 2,
      "name": "brainstorm",
      "timeout_seconds": 300,
      "seed": "after-step-1",
      "artifacts": [
        {"path": ".kiln/docs/VISION.md", "exists": true},
        {"path": ".kiln/docs/vision-notes.md", "exists": true},
        {"path": ".kiln/docs/vision-priorities.md", "exists": true},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "- **stage**: research"},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "step-3-research.md"}
      ]
    },
    {
      "step": 3,
      "name": "research",
      "timeout_seconds": 300,
      "seed": "after-step-2",
      "artifacts": [
        {"path": ".kiln/docs/research.md", "exists": true},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "- **stage**: architecture"},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "step-4-architecture.md"}
      ]
    },
    {
      "step": 4,
      "name": "architecture",
      "timeout_seconds": 420,
      "seed": "after-step-3",
      "artifacts": [
        {"path": ".kiln/docs/architecture.md", "exists": true},
        {"path": ".kiln/docs/tech-stack.md", "exists": true},
        {"path": ".kiln/docs/arch-constraints.md", "exists": true},
        {"path": ".kiln/plans/claude_plan.md", "exists": true},
        {"path": ".kiln/plans/codex_plan.md", "exists": true},
        {"path": ".kiln/plans/plan_validation.md", "exists": true},
        {"path": ".kiln/master-plan.md", "exists": true},
        {"path": ".kiln/architecture-handoff.md", "exists": true},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "- **stage**: build"},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "step-5-build.md"}
      ]
    },
    {
      "step": 5,
      "name": "build",
      "timeout_seconds": 360,
      "seed": "after-step-4",
      "artifacts": [
        {"path": "index.html", "exists": true},
        {"path": "AGENTS.md", "exists": true},
        {"path": ".kiln/docs/codebase-state.md", "exists": true},
        {"path": ".kiln/docs/patterns.md", "exists": true},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "- **stage**: validate"},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "step-6-validate.md"}
      ]
    },
    {
      "step": 6,
      "name": "validate",
      "timeout_seconds": 240,
      "seed": "after-step-5",
      "artifacts": [
        {"path": ".kiln/validation/report.md", "exists": true},
        {"path": ".kiln/validation/architecture-check.md", "exists": true},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "- **stage**: report"},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "step-7-report.md"}
      ]
    },
    {
      "step": 7,
      "name": "report",
      "timeout_seconds": 180,
      "seed": "after-step-6",
      "artifacts": [
        {"path": ".kiln/REPORT.md", "exists": true},
        {"path": ".kiln/STATE.md", "exists": true, "contains": "- **stage**: complete"}
      ]
    }
  ],
  "artifacts": [
    {"path": ".kiln/STATE.md", "exists": true},
    {"path": ".kiln/MEMORY.md", "exists": true},
    {"path": ".kiln/docs/codebase-snapshot.md", "exists": true},
    {"path": ".kiln/docs/decisions.md", "exists": true},
    {"path": ".kiln/docs/VISION.md", "exists": true},
    {"path": ".kiln/docs/vision-notes.md", "exists": true},
    {"path": ".kiln/docs/vision-priorities.md", "exists": true},
    {"path": ".kiln/docs/research.md", "exists": true},
    {"path": ".kiln/docs/architecture.md", "exists": true},
    {"path": ".kiln/docs/tech-stack.md", "exists": true},
    {"path": ".kiln/master-plan.md", "exists": true},
    {"path": ".kiln/docs/codebase-state.md", "exists": true},
    {"path": ".kiln/docs/patterns.md", "exists": true},
    {"path": ".kiln/validation/report.md", "exists": true},
    {"path": ".kiln/REPORT.md", "exists": true}
  ],
  "compliance": [
    {
      "name": "step_isolation",
      "check": "Each step runs in its own fresh seeded workspace and stops after its own state transition",
      "target": true
    },
    {
      "name": "hook_violations",
      "check": "Zero hook blocks across the eight isolated runs",
      "target": 0
    },
    {
      "name": "delegation_compliance",
      "check": "KRS-One, Codex, and planner wrappers follow delegation rules during their isolated steps",
      "target": true
    },
    {
      "name": "headless_protocol",
      "check": "No step waits for human input; steps 1-2 use injected headless answers",
      "target": true
    },
    {
      "name": "state_transitions",
      "check": "Each isolated step advances STATE.md to the next canonical stage",
      "target": true
    }
  ],
  "metrics": {
    "duration_target_seconds": 2340,
    "hook_violations_target": 0,
    "step_timeout_target_seconds": 420,
    "build_timeout_target_seconds": 360
  }
}
